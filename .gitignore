# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
*.tfvars.local
# Root provider lock IS committed (terraform/.terraform.lock.hcl); module-level
# lock files are transient (regenerated by `init` during `terraform test`).
terraform/modules/**/.terraform.lock.hcl

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/

# Secrets / env
.env
*.pem
.secrets

# OS
.DS_Store
Thumbs.db
